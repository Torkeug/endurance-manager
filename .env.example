# Supabase project URL (find it in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (e.g. https://kronos.example.com) — used in email links
NEXT_PUBLIC_APP_URL=

# Resend API key for transactional emails (admin notifications, driver approvals)
RESEND_API_KEY=

# Set to "true" to show test/seed accounts in the driver picker (dev/staging only)
NEXT_PUBLIC_SHOW_TEST_ACCOUNTS=
