# Supabase project URL (find it in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (e.g. https://kronos.example.com) — used in email links and OAuth redirects
NEXT_PUBLIC_APP_URL=

# Resend API key for transactional emails (admin notifications, driver approvals)
RESEND_API_KEY=

# Sender address for notification emails — full format: "App Name <noreply@yourdomain.com>"
EMAIL_FROM=

# Garage61 OAuth client ID (register your app at garage61.net)
NEXT_PUBLIC_GARAGE61_CLIENT_ID=

# Garage61 OAuth client secret (server only)
GARAGE61_CLIENT_SECRET=

# iRacing OAuth client ID (register your app with iRacing)
NEXT_PUBLIC_IRACING_CLIENT_ID=

# Bearer token for iRacing webhook endpoints (/api/iracing/lap and /api/iracing/event)
IRACING_BRIDGE_API_KEY=

# Bearer token for Vercel cron endpoints
CRON_SECRET=

# Set to "true" to show test/seed accounts in the driver picker (dev/staging only)
NEXT_PUBLIC_SHOW_TEST_ACCOUNTS=
